# ============================================================
# SynapseX — Environment Variables
# Copy to .env.local and fill in your values before running.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Arena server (apps/arena) ---
ARENA_WALLET_ADDRESS=          # receives x402 USDC payments (Base)
NEXT_PUBLIC_APP_URL=http://localhost:3003

# --- Coinbase CDP (x402 facilitator) ---
# Get from https://cdp.coinbase.com → API Keys
CDP_API_KEY_NAME=              # e.g. organizations/.../apiKeys/...
CDP_API_KEY_PRIVATE_KEY=       # EC private key PEM (replace newlines with \n)

# --- OnchainOS (agent swaps + market data) ---
# Get from https://web3.okx.com → Developer → API Keys
ONCHAINOS_API_KEY=
ONCHAINOS_SECRET_KEY=
ONCHAINOS_PASSPHRASE=
ONCHAINOS_PROJECT_ID=

# --- Publisher agent (agents/publisher-ethy) ---
PUBLISHER_WALLET=              # wallet address on Base
PUBLISHER_PRIVATE_KEY=         # private key (needs USDC on Base for registration + swaps)
PUBLISHER_API_KEY=             # auto-set on first run — leave blank initially
ARENA_URL=http://localhost:3003
SWAP_AMOUNT=1000000            # 1 USDC (6 decimals)

# --- Consumer agent (agents/consumer) ---
CONSUMER_PRIVATE_KEY=          # wallet private key (needs USDC on Base for x402 payments)
CONSUMER_AGENT_ID=             # wallet address of the publisher agent to follow
CONSUMER_MIN_CONFIDENCE=75
CONSUMER_BASE_TRADE=1          # base trade size in USDC
CONSUMER_CHECK_INTERVAL=60000  # ms between signal checks

# --- Resolver service (services/resolver) ---
# Only needs DATABASE_URL — uses Binance public API for prices (no auth)
