# OKX API credentials (get from https://www.okx.com/account/my-api)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# PostgreSQL Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Arena wallet (receives x402 payments)
ARENA_WALLET_ADDRESS=
ARENA_WALLET_PRIVATE_KEY=

# Publisher agent
PUBLISHER_WALLET=
PUBLISHER_PRIVATE_KEY=
PUBLISHER_API_KEY=
ARENA_URL=http://localhost:3003

# Consumer agent
CONSUMER_PRIVATE_KEY=
CONSUMER_AGENT_ID=0x...  # wallet address of the publisher agent to follow
CONSUMER_MIN_CONFIDENCE=60
CONSUMER_BASE_TRADE=1
CONSUMER_CHECK_INTERVAL=60000
